                        </apply>
                        <ci>Vmax_SRCaP</ci>
                        <ci>Vmax_mult</ci>
                        <apply>
                            <minus/>
                            <apply>
                                <power/>
                                <apply>
                                    <divide/>
                                    <ci>cai</ci>
                                    <ci>Kmf_p</ci>
                                </apply>
                                <ci>hillSRCaP</ci>
                            </apply>
                            <apply>
                                <power/>
                                <apply>
                                    <divide/>
                                    <ci>casr</ci>
                                    <ci>Kmr</ci>
                                </apply>
                                <ci>hillSRCaP</ci>
                            </apply>
                        </apply>
                    </apply>
                    <apply>
                        <plus/>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <power/>
                            <apply>
                                <divide/>
                                <ci>cai</ci>
                                <ci>Kmf_p</ci>
                            </apply>
                            <ci>hillSRCaP</ci>
                        </apply>
                        <apply>
                            <power/>
                            <apply>
                                <divide/>
                                <ci>casr</ci>
                                <ci>Kmr</ci>
                            </apply>
                            <ci>hillSRCaP</ci>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>Jserca</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>Jserca_np</ci>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>phosphorylationTotal</ci>
                        </apply>
                    </apply>
                    <apply>
                        <times/>
                        <ci>Jserca_p</ci>
                        <ci>phosphorylationTotal</ci>
                    </apply>
                </apply>
            </apply>
        </math>
    </component>
    <component name="contraction">
        <variable name="time" public_interface="in" units="millisecond"/>
        <variable name="cai" public_interface="in" units="millimolar"/>
        <variable name="fTnI_PKA" public_interface="in" units="dimensionless"/>
        <variable name="fMyBPC_PKA" public_interface="in" units="dimensionless"/>
        <variable initial_value="0.0031" name="fracTnIpo" units="dimensionless"/>
        <variable name="fPKA_TnI" units="dimensionless"/>
        <variable name="PKAForceMultiplier" units="dimensionless"/>
        <variable initial_value="0.35" name="perm50" units="dimensionless"/>
        <variable initial_value="1.65" name="TRPN_n" units="dimensionless"/>
        <variable initial_value="0.07854" name="koff" units="per_millisecond"/>
        <variable initial_value="0.25" name="dr" units="dimensionless"/>
        <variable initial_value="0.5" name="wfrac" units="dimensionless"/>
        <variable initial_value="25" name="TOT_A" units="dimensionless"/>
        <variable initial_value="0.02626" name="ktm_unblock" units="dimensionless"/>
        <variable initial_value="2.3" name="beta_0" units="dimensionless"/>
        <variable initial_value="-2.4" name="beta_1" units="dimensionless"/>
        <variable initial_value="0.0085" name="gamma" units="dimensionless"/>
        <variable initial_value="0.615" name="gamma_wu" units="dimensionless"/>
        <variable initial_value="2.23" name="phi" units="dimensionless"/>
        <variable initial_value="2.036" name="nperm" units="dimensionless"/>
        <variable name="ca50" units="dimensionless"/>
        <variable initial_value="80" name="Tref" units="kilopascal"/>
        <variable initial_value="10.15996" name="nu" units="dimensionless"/>
        <variable initial_value="3.94046" name="mu" units="dimensionless"/>
        <variable name="k_ws" units="dimensionless"/>
        <variable name="k_uw" units="dimensionless"/>
        <variable name="k_wu" units="dimensionless"/>
        <variable name="k_su" units="dimensionless"/>
        <variable initial_value="1" name="lambda" units="dimensionless"/>
        <variable initial_value="0.87" name="lambda_min" units="dimensionless"/>
        <variable initial_value="1.2" name="lambda_max" units="dimensionless"/>
        <variable name="lambda0" units="dimensionless"/>
        <variable initial_value="0" name="lambda_rate" units="per_millisecond"/>
        <variable name="cdw" units="dimensionless"/>
        <variable name="cds" units="dimensionless"/>
        <variable name="A" units="dimensionless"/>
        <variable name="Lfac" units="dimensionless"/>
        <variable name="XU" units="dimensionless"/>
        <variable initial_value="0.992378492940848" name="contraction_TmBlocked" units="dimensionless"/>
        <variable initial_value="0.00285370717430549" name="contraction_XW" units="dimensionless"/>
        <variable initial_value="0.00191507884532543" name="contraction_XS" units="dimensionless"/>
        <variable name="xb_ws" units="dimensionless"/>
        <variable name="xb_uw" units="dimensionless"/>
        <variable name="xb_wu" units="dimensionless"/>
        <variable name="xb_su" units="dimensionless"/>
        <variable initial_value="0" name="contraction_ZETAS" units="dimensionless"/>
        <variable name="gamma_rate" units="dimensionless"/>
        <variable name="xb_su_gamma" units="dimensionless"/>
        <variable name="gamma_rate_w" units="dimensionless"/>
        <variable initial_value="0" name="contraction_ZETAW" units="dimensionless"/>
        <variable name="xb_wu_gamma" units="dimensionless"/>
        <variable initial_value="0.0319778784167468" name="contraction_Ca_TRPN" units="dimensionless"/>
        <variable name="d_contraction_Ca_TRPN" public_interface="out" units="per_millisecond"/>
        <variable name="XSSS" units="dimensionless"/>
        <variable name="XWSS" units="dimensionless"/>
        <variable name="ktm_block" units="dimensionless"/>
        <variable name="Ta" units="kilopascal"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>fPKA_TnI</ci>
                <apply>
                    <minus/>
                    <cn cellml:units="dimensionless">1.45</cn>
                    <apply>
                        <divide/>
                        <apply>
                            <times/>
                            <cn cellml:units="dimensionless">0.45</cn>
                            <apply>
                                <minus/>
                                <cn cellml:units="dimensionless">1</cn>
                                <ci>fTnI_PKA</ci>
                            </apply>
                        </apply>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>fracTnIpo</ci>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>PKAForceMultiplier</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">1.0</cn>
                    <apply>
                        <times/>
                        <cn cellml:units="dimensionless">0.26</cn>
                        <ci>fMyBPC_PKA</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>k_ws</ci>
                <apply>
                    <times/>
                    <cn cellml:units="dimensionless">0.004</cn>
                    <apply>
                        <plus/>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <divide/>
                            <ci>fMyBPC_PKA</ci>
                            <cn cellml:units="dimensionless">2</cn>
                        </apply>
                    </apply>
                    <ci>mu</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>k_uw</ci>
                <apply>
                    <times/>
                    <cn cellml:units="dimensionless">0.026</cn>
                    <ci>nu</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>cdw</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <ci>phi</ci>
                        <ci>k_uw</ci>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>wfrac</ci>
                        </apply>
                    </apply>
                    <ci>wfrac</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>cds</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <ci>phi</ci>
                        <ci>k_ws</ci>
                        <ci>wfrac</ci>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>dr</ci>
                        </apply>
                    </apply>
                    <ci>dr</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>k_wu</ci>
                <apply>
                    <minus/>
                    <apply>
                        <times/>
                        <ci>k_uw</ci>
                        <apply>
                            <minus/>
                            <apply>
                                <divide/>
                                <cn cellml:units="dimensionless">1</cn>
                                <ci>wfrac</ci>
                            </apply>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </apply>
                    <ci>k_ws</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>k_su</ci>
                <apply>
                    <times/>
                    <ci>k_ws</ci>
                    <apply>
                        <minus/>
                        <apply>
                            <divide/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>dr</ci>
                        </apply>
                        <cn cellml:units="dimensionless">1</cn>
                    </apply>
                    <ci>wfrac</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>A</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <ci>TOT_A</ci>
                        <ci>dr</ci>
                    </apply>
                    <apply>
                        <plus/>
                        <apply>
                            <times/>
                            <apply>
                                <minus/>
                                <cn cellml:units="dimensionless">1</cn>
                                <ci>dr</ci>
                            </apply>
                            <ci>wfrac</ci>
                        </apply>
                        <ci>dr</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>lambda0</ci>
                <apply>
                    <min/>
                    <ci>lambda_max</ci>
                    <ci>lambda</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>Lfac</ci>
                <apply>
                    <max/>
                    <cn cellml:units="dimensionless">0</cn>
                    <apply>
                        <plus/>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <times/>
                            <ci>beta_0</ci>
                            <apply>
                                <minus/>
                                <apply>
                                    <plus/>
                                    <ci>lambda0</ci>
                                    <apply>
                                        <min/>
                                        <ci>lambda_min</ci>
                                        <ci>lambda0</ci>
                                    </apply>
                                </apply>
                                <apply>
                                    <plus/>
                                    <cn cellml:units="dimensionless">1</cn>
                                    <ci>lambda_min</ci>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>XU</ci>
                <apply>
                    <minus/>
                    <apply>
                        <minus/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>contraction_TmBlocked</ci>
                        </apply>
                        <ci>contraction_XW</ci>
                    </apply>
                    <ci>contraction_XS</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>xb_ws</ci>
                <apply>
                    <times/>
                    <ci>k_ws</ci>
                    <ci>contraction_XW</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>xb_uw</ci>
                <apply>
                    <times/>
                    <ci>k_uw</ci>
                    <ci>XU</ci>
                    <apply>
                        <plus/>
                        <cn cellml:units="dimensionless">1.0</cn>
                        <apply>
                            <divide/>
                            <ci>fMyBPC_PKA</ci>
                            <cn cellml:units="dimensionless">2</cn>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>xb_wu</ci>
                <apply>
                    <times/>
                    <ci>k_wu</ci>
                    <ci>contraction_XW</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>xb_su</ci>
                <apply>
                    <times/>
                    <ci>k_su</ci>
                    <ci>contraction_XS</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>gamma_rate</ci>
                <piecewise>
                    <piece>
                        <apply>
                            <times/>
                            <ci>gamma</ci>
                            <ci>contraction_ZETAS</ci>
                        </apply>
                        <apply>
                            <gt/>
                            <ci>contraction_ZETAS</ci>
                            <cn cellml:units="dimensionless">0</cn>
                        </apply>
                    </piece>
                    <piece>
                        <apply>
                            <times/>
                            <ci>gamma</ci>
                            <apply>
                                <minus/>
                                <apply>
                                    <minus/>
                                    <ci>contraction_ZETAS</ci>
                                </apply>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                        </apply>
                        <apply>
                            <lt/>
                            <ci>contraction_ZETAS</ci>
                            <apply>
                                <minus/>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                        </apply>
                    </piece>
                    <otherwise>
                        <cn cellml:units="dimensionless">0.0</cn>
                    </otherwise>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>xb_su_gamma</ci>
                <apply>
                    <times/>
                    <ci>gamma_rate</ci>
                    <ci>contraction_XS</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>gamma_rate_w</ci>
                <apply>
                    <times/>
                    <ci>gamma_wu</ci>
                    <apply>
                        <abs/>
                        <ci>contraction_ZETAW</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>xb_wu_gamma</ci>
                <apply>
                    <times/>
                    <ci>gamma_rate_w</ci>
                    <ci>contraction_XW</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>time</ci>
                    </bvar>
                    <ci>contraction_XS</ci>
                </apply>
                <apply>
                    <minus/>
                    <apply>
                        <minus/>
                        <ci>xb_ws</ci>
                        <ci>xb_su</ci>
                    </apply>
                    <ci>xb_su_gamma</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>time</ci>
                    </bvar>
                    <ci>contraction_XW</ci>
                </apply>
                <apply>
                    <minus/>
                    <apply>
                        <minus/>
                        <apply>
                            <minus/>
                            <ci>xb_uw</ci>
                            <ci>xb_wu</ci>
                        </apply>
                        <ci>xb_ws</ci>
                    </apply>
                    <ci>xb_wu_gamma</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>ca50</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>fPKA_TnI</ci>
                        <cn cellml:units="dimensionless">0.7645</cn>
                    </apply>
                    <apply>
                        <times/>
                        <ci>beta_1</ci>
                        <apply>
                            <min/>
                            <cn cellml:units="dimensionless">0.2</cn>
                            <apply>
                                <minus/>
                                <ci>lambda</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>d_contraction_Ca_TRPN</ci>
                <apply>
                    <times/>
                    <ci>koff</ci>
                    <apply>
                        <minus/>
                        <apply>
                            <times/>
                            <apply>
                                <power/>
                                <apply>
                                    <divide/>
                                    <apply>
                                        <times/>
                                        <ci>cai</ci>
                                        <cn cellml:units="per_millimolar">1000</cn>
                                    </apply>
                                    <ci>ca50</ci>
                                </apply>
                                <ci>TRPN_n</ci>
                            </apply>
                            <apply>
                                <minus/>
                                <cn cellml:units="dimensionless">1</cn>
                                <ci>contraction_Ca_TRPN</ci>
                            </apply>
                        </apply>
                        <ci>contraction_Ca_TRPN</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>time</ci>
                    </bvar>
                    <ci>contraction_Ca_TRPN</ci>
                </apply>
                <ci>d_contraction_Ca_TRPN</ci>
            </apply>
            <apply>
                <eq/>
                <ci>XSSS</ci>
                <apply>
                    <times/>
                    <ci>dr</ci>
                    <cn cellml:units="dimensionless">0.5</cn>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>XWSS</ci>
                <apply>
                    <times/>
                    <apply>
                        <minus/>
                        <cn cellml:units="dimensionless">1</cn>
                        <ci>dr</ci>
                    </apply>
                    <ci>wfrac</ci>
                    <cn cellml:units="dimensionless">0.5</cn>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>ktm_block</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <ci>ktm_unblock</ci>
                        <apply>
                            <power/>
                            <ci>perm50</ci>
                            <ci>nperm</ci>
                        </apply>
                        <cn cellml:units="dimensionless">0.5</cn>
                    </apply>
                    <apply>
                        <minus/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">0.5</cn>
                            <ci>XSSS</ci>
                        </apply>
                        <ci>XWSS</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>time</ci>
                    </bvar>
                    <ci>contraction_TmBlocked</ci>
                </apply>
                <apply>
                    <minus/>
                    <apply>
                        <times/>
                        <ci>ktm_block</ci>
                        <apply>
                            <min/>
                            <cn cellml:units="dimensionless">100</cn>
                            <apply>
                                <power/>
                                <ci>contraction_Ca_TRPN</ci>
                                <apply>
                                    <divide/>
                                    <apply>
                                        <minus/>
                                        <ci>nperm</ci>
                                    </apply>
                                    <cn cellml:units="dimensionless">2</cn>
                                </apply>
                            </apply>
                        </apply>
                        <ci>XU</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>ktm_unblock</ci>
                        <apply>
                            <power/>
                            <ci>contraction_Ca_TRPN</ci>
                            <apply>
                                <divide/>
                                <ci>nperm</ci>
                                <cn cellml:units="dimensionless">2</cn>
                            </apply>
                        </apply>
                        <ci>contraction_TmBlocked</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>time</ci>
                    </bvar>
                    <ci>contraction_ZETAS</ci>
                </apply>
                <apply>
                    <minus/>
                    <apply>
                        <times/>
                        <ci>A</ci>
                        <ci>lambda_rate</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>cds</ci>
                        <ci>contraction_ZETAS</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>time</ci>
                    </bvar>
                    <ci>contraction_ZETAW</ci>
                </apply>
                <apply>
                    <minus/>
                    <apply>
                        <times/>
                        <ci>A</ci>
                        <ci>lambda_rate</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>cdw</ci>
                        <ci>contraction_ZETAW</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>Ta</ci>
                <apply>
                    <times/>
                    <apply>
                        <divide/>
                        <apply>
                            <times/>
                            <ci>Lfac</ci>
                            <ci>PKAForceMultiplier</ci>
                            <ci>Tref</ci>
                        </apply>
                        <ci>dr</ci>
                    </apply>
                    <apply>
                        <plus/>
                        <apply>
                            <times/>
                            <apply>
                                <plus/>
                                <ci>contraction_ZETAS</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <ci>contraction_XS</ci>
                        </apply>
                        <apply>
                            <times/>
                            <ci>contraction_ZETAW</ci>
                            <ci>contraction_XW</ci>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
    </component>
    <component name="PKA">
        <variable initial_value="0" name="fINa_PKA" public_interface="out" units="dimensionless"/>
        <variable initial_value="0" name="fICaL_PKA" public_interface="out" units="dimensionless"/>
        <variable initial_value="0" name="fINaK_PKA" public_interface="out" units="dimensionless"/>
        <variable initial_value="0" name="fIKs_PKA" public_interface="out" units="dimensionless"/>
        <variable initial_value="0" name="fPLB_PKA" public_interface="out" units="dimensionless"/>
        <variable initial_value="0" name="fTnI_PKA" public_interface="out" units="dimensionless"/>
        <variable initial_value="0" name="fMyBPC_PKA" public_interface="out" units="dimensionless"/>
    </component>
    <!-- MAPPINGS-->
    <connection>
