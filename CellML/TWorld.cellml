<?xml version='1.0' encoding='UTF-8'?>
<!--
  Title:     "T-World: A highly general computational model of a human ventricular myocyte"
  Authors:   Jakub Tomek, Xin Zhou, Hector Martinez-Navarro, Maxx Holmes, Thomas Bury, Lucas Arantes Berg, Marketa Tomkova, Emily Jo, Norbert Nagy, Ambre Bertrand, 
             Alfonso Bueno-Orovio, Michael A Colman, Blanca Rodriguez, Donald M Bers, Jordi Heijman. 
  Reference: https://doi.org/10.1101/2025.03.24.645031 (to be updated with final publication details)

  CellML implementation: 18/06/2025, Alfonso Bueno-Orovio, University of Oxford.
  [This code makes use of portions of a previous implementation of the ToR-ORd model]-->
<model name="TWorld" xmlns="http://www.cellml.org/cellml/1.0#" xmlns:cellml="http://www.cellml.org/cellml/1.0#">
    <!-- UNITS-->
    <units name="millisecond">
        <unit prefix="milli" units="second"/>
    </units>
    <units name="per_millisecond">
        <unit exponent="-1" units="millisecond"/>
    </units>
    <units name="millivolt">
        <unit prefix="milli" units="volt"/>
    </units>
    <units name="millivolt_square">
        <unit exponent="2" prefix="milli" units="volt"/>
    </units>
    <units name="per_millivolt">
        <unit exponent="-1" units="millivolt"/>
    </units>
    <units name="millimolar">
        <unit prefix="milli" units="mole"/>
        <unit exponent="-1" units="litre"/>
    </units>
    <units name="per_millimolar">
        <unit exponent="-1" units="millimolar"/>
    </units>
    <units name="millimolar_per_millisecond">
        <unit units="millimolar"/>
        <unit exponent="-1" units="millisecond"/>
    </units>
    <units name="per_millimolar_per_millisecond">
        <unit exponent="-1" units="millimolar"/>
        <unit exponent="-1" units="millisecond"/>
    </units>
    <units name="microF">
        <unit prefix="micro" units="farad"/>
    </units>
    <units name="microA_per_microF">
        <unit prefix="micro" units="ampere"/>
        <unit exponent="-1" prefix="micro" units="farad"/>
    </units>
    <units name="milliS_per_microF">
        <unit prefix="milli" units="siemens"/>
        <unit exponent="-1" prefix="micro" units="farad"/>
    </units>
    <units name="micrometer">
        <unit prefix="micro" units="metre"/>
    </units>
    <units name="liter_per_micrometer_cubed">
        <unit units="liter"/>
        <unit exponent="-3" units="micrometer"/>
    </units>
    <units name="microliter">
        <unit prefix="micro" units="liter"/>
    </units>
    <units name="joule_per_kilomole_kelvin">
        <unit units="joule"/>
        <unit exponent="-1" prefix="kilo" units="mole"/>
        <unit exponent="-1" units="kelvin"/>
    </units>
    <units name="coulomb_per_mole">
        <unit units="coulomb"/>
        <unit exponent="-1" units="mole"/>
    </units>
    <units name="per_kelvin">
        <unit exponent="-1" units="kelvin"/>
    </units>
    <units name="kilopascal">
        <unit prefix="kilo" units="pascal"/>
    </units>
    <!-- COMPARTMENTS-->
    <component name="environment">
        <variable name="time" public_interface="out" units="millisecond"/>
        <!-- celltype: 0 (endo), 1 (epi), 2 (m)-->
        <variable initial_value="0" name="celltype" public_interface="out" units="dimensionless"/>
        <!-- sex: 0 (none), 1 (male), 2 (female)-->
        <variable initial_value="0" name="sex" public_interface="out" units="dimensionless"/>
    </component>
    <component name="multipliers">
        <variable initial_value="1" name="INa_multiplier" public_interface="out" units="dimensionless"/>
        <variable initial_value="1" name="INaL_multiplier" public_interface="out" units="dimensionless"/>
        <variable initial_value="1" name="INab_multiplier" public_interface="out" units="dimensionless"/>
        <variable initial_value="1" name="INaK_multiplier" public_interface="out" units="dimensionless"/>
        <variable initial_value="1" name="IClCa_multiplier" public_interface="out" units="dimensionless"/>
        <variable initial_value="1" name="IClb_multiplier" public_interface="out" units="dimensionless"/>
        <variable initial_value="1" name="Itos_multiplier" public_interface="out" units="dimensionless"/>
        <variable initial_value="1" name="Itof_multiplier" public_interface="out" units="dimensionless"/>
        <variable initial_value="1" name="IKb_multiplier" public_interface="out" units="dimensionless"/>
        <variable initial_value="1" name="ICaLPCa_multiplier" public_interface="out" units="dimensionless"/>
        <variable initial_value="1" name="ICab_multiplier" public_interface="out" units="dimensionless"/>
        <variable initial_value="1" name="Jrel_multiplier" public_interface="out" units="dimensionless"/>
        <variable initial_value="1" name="Jup_multiplier" public_interface="out" units="dimensionless"/>
        <variable initial_value="1" name="INaCa_multiplier" public_interface="out" units="dimensionless"/>
        <variable initial_value="1" name="IKr_multiplier" public_interface="out" units="dimensionless"/>
        <variable initial_value="1" name="IKs_multiplier" public_interface="out" units="dimensionless"/>
        <variable initial_value="1" name="IK1_multiplier" public_interface="out" units="dimensionless"/>
        <variable initial_value="1" name="IpCa_multiplier" public_interface="out" units="dimensionless"/>
    </component>
    <component name="cell_geometry">
        <variable initial_value="100" name="cellLength" units="micrometer"/>
        <variable initial_value="10.25" name="cellRadius" units="micrometer"/>
        <variable name="vcell" public_interface="out" units="liter"/>
        <variable name="vmyo" public_interface="out" units="liter"/>
        <variable name="vsr" public_interface="out" units="liter"/>
        <variable name="vsl" public_interface="out" units="liter"/>
        <variable name="vjunc" public_interface="out" units="liter"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>vcell</ci>
                <apply>
                    <times/>
                    <cn cellml:units="liter_per_micrometer_cubed" type="e-notation">1<sep/>-15</cn>
                    <pi/>
                    <apply>
                        <power/>
                        <ci>cellRadius</ci>
                        <cn cellml:units="dimensionless">2</cn>
                    </apply>
                    <ci>cellLength</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>vmyo</ci>
                <apply>
                    <times/>
                    <cn cellml:units="dimensionless">0.65</cn>
                    <ci>vcell</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>vsr</ci>
                <apply>
                    <times/>
                    <cn cellml:units="dimensionless">0.035</cn>
                    <ci>vcell</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>vsl</ci>
                <apply>
                    <times/>
                    <cn cellml:units="dimensionless">0.02</cn>
                    <ci>vcell</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>vjunc</ci>
                <apply>
                    <times/>
                    <cn cellml:units="dimensionless" type="e-notation">5.39<sep/>-4</cn>
                    <ci>vcell</ci>
                </apply>
            </apply>
        </math>
    </component>
    <component name="extracellular">
        <variable initial_value="140.0" name="nao" public_interface="out" units="millimolar"/>
        <variable initial_value="1.8" name="cao" public_interface="out" units="millimolar"/>
        <variable initial_value="5.0" name="ko" public_interface="out" units="millimolar"/>
        <variable initial_value="150.0" name="clo" public_interface="out" units="millimolar"/>
    </component>
    <component name="physical_constants">
        <variable initial_value="8314" name="R" public_interface="out" units="joule_per_kilomole_kelvin"/>
        <variable initial_value="310" name="T" public_interface="out" units="kelvin"/>
        <variable initial_value="96485" name="F" public_interface="out" units="coulomb_per_mole"/>
        <variable name="Qpow" public_interface="out" units="dimensionless"/>
        <variable initial_value="1" name="zna" public_interface="out" units="dimensionless"/>
        <variable initial_value="2" name="zca" public_interface="out" units="dimensionless"/>
        <variable initial_value="1" name="zk" public_interface="out" units="dimensionless"/>
        <variable initial_value="-1" name="zcl" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>Qpow</ci>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>T</ci>
                        <cn cellml:units="dimensionless">310</cn>
                    </apply>
                    <cn cellml:units="dimensionless">10</cn>
                </apply>
            </apply>
        </math>
    </component>
    <component name="reversal_potentials">
        <variable initial_value="0.01833" name="PNaK" units="dimensionless"/>
        <variable name="ENaj" public_interface="out" units="millivolt"/>
        <variable name="ENasl" public_interface="out" units="millivolt"/>
        <variable name="EK" public_interface="out" units="millivolt"/>
        <variable name="EKs" public_interface="out" units="millivolt"/>
        <variable name="ECl" public_interface="out" units="millivolt"/>
        <variable name="ECaj" public_interface="out" units="millivolt"/>
        <variable name="ECasl" public_interface="out" units="millivolt"/>
        <variable name="nao" public_interface="in" units="millimolar"/>
        <variable name="nai" public_interface="in" units="millimolar"/>
        <variable name="naj" public_interface="in" units="millimolar"/>
        <variable name="nasl" public_interface="in" units="millimolar"/>
        <variable name="cao" public_interface="in" units="millimolar"/>
        <variable name="caj" public_interface="in" units="millimolar"/>
        <variable name="casl" public_interface="in" units="millimolar"/>
        <variable name="ko" public_interface="in" units="millimolar"/>
        <variable name="ki" public_interface="in" units="millimolar"/>
        <variable name="clo" public_interface="in" units="millimolar"/>
        <variable name="cli" public_interface="in" units="millimolar"/>
        <variable name="zna" public_interface="in" units="dimensionless"/>
        <variable name="zca" public_interface="in" units="dimensionless"/>
        <variable name="zk" public_interface="in" units="dimensionless"/>
        <variable name="zcl" public_interface="in" units="dimensionless"/>
        <variable name="R" public_interface="in" units="joule_per_kilomole_kelvin"/>
        <variable name="T" public_interface="in" units="kelvin"/>
        <variable name="F" public_interface="in" units="coulomb_per_mole"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>ENaj</ci>
                <apply>
                    <times/>
                    <apply>
                        <divide/>
                        <apply>
                            <times/>
                            <ci>R</ci>
                            <ci>T</ci>
                        </apply>
                        <apply>
                            <times/>
                            <ci>zna</ci>
                            <ci>F</ci>
                        </apply>
                    </apply>
                    <apply>
                        <ln/>
                        <apply>
                            <divide/>
                            <ci>nao</ci>
                            <ci>naj</ci>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>ENasl</ci>
                <apply>
                    <times/>
                    <apply>
                        <divide/>
                        <apply>
                            <times/>
                            <ci>R</ci>
                            <ci>T</ci>
                        </apply>
                        <apply>
                            <times/>
                            <ci>zna</ci>
                            <ci>F</ci>
                        </apply>
                    </apply>
                    <apply>
                        <ln/>
                        <apply>
                            <divide/>
                            <ci>nao</ci>
                            <ci>nasl</ci>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>EK</ci>
                <apply>
                    <times/>
                    <apply>
                        <divide/>
                        <apply>
                            <times/>
                            <ci>R</ci>
                            <ci>T</ci>
                        </apply>
                        <apply>
                            <times/>
                            <ci>zk</ci>
                            <ci>F</ci>
                        </apply>
                    </apply>
                    <apply>
                        <ln/>
                        <apply>
                            <divide/>
                            <ci>ko</ci>
                            <ci>ki</ci>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>EKs</ci>
                <apply>
                    <times/>
                    <apply>
                        <divide/>
                        <apply>
                            <times/>
                            <ci>R</ci>
                            <ci>T</ci>
                        </apply>
                        <apply>
                            <times/>
                            <ci>zk</ci>
                            <ci>F</ci>
                        </apply>
                    </apply>
                    <apply>
                        <ln/>
                        <apply>
                            <divide/>
                            <apply>
                                <plus/>
                                <ci>ko</ci>
                                <apply>
                                    <times/>
                                    <ci>PNaK</ci>
                                    <ci>nao</ci>
                                </apply>
                            </apply>
                            <apply>
                                <plus/>
                                <ci>ki</ci>
                                <apply>
                                    <times/>
                                    <ci>PNaK</ci>
                                    <ci>nai</ci>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>ECl</ci>
                <apply>
                    <times/>
                    <apply>
                        <divide/>
                        <apply>
                            <times/>
                            <ci>R</ci>
                            <ci>T</ci>
                        </apply>
                        <apply>
                            <times/>
                            <ci>zcl</ci>
                            <ci>F</ci>
                        </apply>
                    </apply>
                    <apply>
                        <ln/>
                        <apply>
                            <divide/>
                            <ci>clo</ci>
                            <ci>cli</ci>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>ECaj</ci>
                <apply>
                    <times/>
                    <apply>
                        <divide/>
                        <apply>
                            <times/>
                            <ci>R</ci>
                            <ci>T</ci>
                        </apply>
                        <apply>
                            <times/>
                            <ci>zca</ci>
                            <ci>F</ci>
                        </apply>
                    </apply>
                    <apply>
                        <ln/>
                        <apply>
                            <divide/>
                            <ci>cao</ci>
                            <ci>caj</ci>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>ECasl</ci>
                <apply>
                    <times/>
                    <apply>
                        <divide/>
                        <apply>
                            <times/>
                            <ci>R</ci>
                            <ci>T</ci>
                        </apply>
                        <apply>
                            <times/>
                            <ci>zca</ci>
                            <ci>F</ci>
                        </apply>
                    </apply>
                    <apply>
                        <ln/>
                        <apply>
                            <divide/>
                            <ci>cao</ci>
                            <ci>casl</ci>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
    </component>
    <component name="membrane">
        <variable name="time" public_interface="in" units="millisecond"/>
        <variable name="R" public_interface="in" units="joule_per_kilomole_kelvin"/>
        <variable name="T" public_interface="in" units="kelvin"/>
        <variable name="F" public_interface="in" units="coulomb_per_mole"/>
        <variable name="I_tot" public_interface="in" units="microA_per_microF"/>
        <variable initial_value="1.3810e-10" name="Cmem" public_interface="out" units="farad"/>
        <variable initial_value="-87.0655895407835" name="v" public_interface="out" units="millivolt"/>
        <variable name="vffrt" public_interface="out" units="coulomb_per_mole"/>
        <variable name="vfrt" public_interface="out" units="dimensionless"/>
        <variable initial_value="0.11" name="Fjunc" public_interface="out" units="dimensionless"/>
        <variable name="Fsl" public_interface="out" units="dimensionless"/>
        <variable name="Istim" public_interface="out" units="microA_per_microF"/>
        <variable initial_value="0" name="i_Stim_Start" units="millisecond"/>
        <variable initial_value="-53" name="i_Stim_Amplitude" units="microA_per_microF"/>
        <variable initial_value="1000" name="i_Stim_Period" units="millisecond"/>
        <variable initial_value="1.0" name="i_Stim_PulseDuration" units="millisecond"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>Fsl</ci>
                <apply>
                    <minus/>
                    <cn cellml:units="dimensionless">1.0</cn>
                    <ci>Fjunc</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>Istim</ci>
                <piecewise>
                    <piece>
                        <ci>i_Stim_Amplitude</ci>
                        <apply>
                            <and/>
                            <apply>
                                <geq/>
                                <ci>time</ci>
                                <ci>i_Stim_Start</ci>
                            </apply>
                            <apply>
                                <leq/>
                                <apply>
                                    <minus/>
                                    <apply>
                                        <minus/>
                                        <ci>time</ci>
                                        <ci>i_Stim_Start</ci>
                                    </apply>
                                    <apply>
                                        <times/>
                                        <apply>
                                            <floor/>
                                            <apply>
                                                <divide/>
                                                <apply>
                                                    <minus/>
                                                    <ci>time</ci>
                                                    <ci>i_Stim_Start</ci>
                                                </apply>
                                                <ci>i_Stim_Period</ci>
                                            </apply>
                                        </apply>
                                        <ci>i_Stim_Period</ci>
                                    </apply>
                                </apply>
                                <ci>i_Stim_PulseDuration</ci>
                            </apply>
                        </apply>
                    </piece>
                    <otherwise>
                        <cn cellml:units="microA_per_microF">0</cn>
                    </otherwise>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>vffrt</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <ci>v</ci>
                        <ci>F</ci>
                        <ci>F</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>R</ci>
                        <ci>T</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>vfrt</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <ci>v</ci>
                        <ci>F</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>R</ci>
                        <ci>T</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>time</ci>
                    </bvar>
                    <ci>v</ci>
                </apply>
                <apply>
                    <minus/>
                    <ci>I_tot</ci>
                </apply>
            </apply>
        </math>
    </component>
    <component name="CaMK">
        <variable name="time" public_interface="in" units="millisecond"/>
        <variable name="caj" public_interface="in" units="millimolar"/>
        <variable initial_value="0.13698" name="Whole_cell_PP1" units="dimensionless"/>
        <variable name="PP1_tot" units="dimensionless"/>
        <variable initial_value="0.0414775695414329" name="camk_trap" units="millimolar"/>
        <variable initial_value="0.1" name="CaMK0" units="dimensionless"/>
        <variable initial_value="0.0075" name="Km_CaMK_Ca" units="millimolar"/>
        <variable name="bound" units="millimolar"/>
        <variable name="CaMK_active" units="millimolar"/>
        <variable initial_value="0.05" name="alpha" units="per_millimolar_per_millisecond"/>
        <variable initial_value="6.8e-4" name="beta" units="per_millisecond"/>
        <variable initial_value="100000" name="tau_plb" units="millisecond"/>
        <variable initial_value="10000" name="tau_ryr" units="millisecond"/>
        <variable name="tau_cal" units="millisecond"/>
        <variable initial_value="0.35" name="K_Phos_CaMK" units="millimolar"/>
        <variable name="CaMK_Phos_ss_ICaL" units="dimensionless"/>
        <variable name="CaMK_Phos_ss_RyR" units="dimensionless"/>
        <variable name="CaMK_Phos_ss_PLB" units="dimensionless"/>
        <variable initial_value="0.149310462149601" name="camk_f_ICaL" public_interface="out" units="dimensionless"/>
        <variable initial_value="0.0583425856770706" name="camk_f_RyR" public_interface="out" units="dimensionless"/>
        <variable initial_value="0.0102519516890396" name="camk_f_PLB" public_interface="out" units="dimensionless"/>
        <variable initial_value="0.05" name="alpha_serca" units="per_millimolar_per_millisecond"/>
        <variable name="bound_serca" units="millimolar"/>
        <variable initial_value="0.0414775695414004" name="casig_serca_trap" public_interface="out" units="millimolar"/>
        <variable name="casig_SERCA_act" public_interface="out" units="millimolar"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>PP1_tot</ci>
                <ci>Whole_cell_PP1</ci>
            </apply>
            <apply>
                <eq/>
                <ci>bound</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <ci>CaMK0</ci>
                        <apply>
                            <minus/>
                            <cn cellml:units="millimolar">1</cn>
                            <ci>camk_trap</ci>
                        </apply>
                    </apply>
                    <apply>
                        <plus/>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <divide/>
                            <ci>Km_CaMK_Ca</ci>
                            <ci>caj</ci>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>CaMK_active</ci>
                <apply>
                    <plus/>
                    <ci>bound</ci>
                    <ci>camk_trap</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>time</ci>
                    </bvar>
                    <ci>camk_trap</ci>
                </apply>
                <apply>
                    <minus/>
                    <apply>
                        <times/>
                        <ci>alpha</ci>
                        <ci>bound</ci>
                        <ci>CaMK_active</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>beta</ci>
                        <ci>camk_trap</ci>
                        <apply>
                            <plus/>
                            <cn cellml:units="dimensionless">0.1</cn>
                            <apply>
                                <divide/>
                                <apply>
                                    <times/>
                                    <cn cellml:units="dimensionless">0.9</cn>
                                    <ci>PP1_tot</ci>
                                </apply>
                                <cn cellml:units="dimensionless">0.1371</cn>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>tau_cal</ci>
                <ci>tau_ryr</ci>
            </apply>
            <apply>
                <eq/>
                <ci>CaMK_Phos_ss_ICaL</ci>
                <apply>
                    <divide/>
                    <ci>CaMK_active</ci>
                    <apply>
                        <plus/>
                        <ci>CaMK_active</ci>
                        <ci>K_Phos_CaMK</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>CaMK_Phos_ss_RyR</ci>
                <apply>
                    <divide/>
                    <ci>CaMK_active</ci>
                    <apply>
                        <plus/>
                        <ci>CaMK_active</ci>
                        <cn cellml:units="millimolar">1</cn>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>CaMK_Phos_ss_PLB</ci>
                <apply>
                    <divide/>
                    <ci>CaMK_active</ci>
                    <apply>
                        <plus/>
                        <ci>CaMK_active</ci>
                        <cn cellml:units="millimolar">10</cn>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>time</ci>
                    </bvar>
                    <ci>camk_f_ICaL</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>CaMK_Phos_ss_ICaL</ci>
                        <ci>camk_f_ICaL</ci>
                    </apply>
                    <ci>tau_cal</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>time</ci>
                    </bvar>
                    <ci>camk_f_RyR</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>CaMK_Phos_ss_RyR</ci>
                        <ci>camk_f_RyR</ci>
                    </apply>
                    <ci>tau_ryr</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>time</ci>
                    </bvar>
                    <ci>camk_f_PLB</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>CaMK_Phos_ss_PLB</ci>
                        <ci>camk_f_PLB</ci>
                    </apply>
                    <ci>tau_plb</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>bound_serca</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <ci>CaMK0</ci>
                        <apply>
                            <minus/>
                            <cn cellml:units="millimolar">1</cn>
                            <ci>casig_serca_trap</ci>
                        </apply>
                    </apply>
                    <apply>
                        <plus/>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <divide/>
                            <ci>Km_CaMK_Ca</ci>
                            <ci>caj</ci>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>casig_SERCA_act</ci>
                <apply>
                    <plus/>
                    <ci>bound_serca</ci>
                    <ci>casig_serca_trap</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>time</ci>
                    </bvar>
                    <ci>casig_serca_trap</ci>
                </apply>
                <apply>
                    <minus/>
                    <apply>
                        <times/>
                        <ci>alpha_serca</ci>
                        <ci>bound_serca</ci>
                        <ci>casig_SERCA_act</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>beta</ci>
                        <ci>casig_serca_trap</ci>
                        <apply>
                            <plus/>
                            <cn cellml:units="dimensionless">0.1</cn>
                            <apply>
                                <divide/>
                                <apply>
                                    <times/>
                                    <cn cellml:units="dimensionless">0.9</cn>
                                    <ci>PP1_tot</ci>
                                </apply>
                                <cn cellml:units="dimensionless">0.1371</cn>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
    </component>
