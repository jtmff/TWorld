        <map_variables variable_1="zk" variable_2="zk"/>
        <map_variables variable_1="zcl" variable_2="zcl"/>
    </connection>
    <connection>
        <map_components component_1="intracellular_ions" component_2="CaMK"/>
        <map_variables variable_1="caj" variable_2="caj"/>
